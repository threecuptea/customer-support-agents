# ─────────────────────────────────────────────────────────────
#  LLM configuration (provider-agnostic via langchain init_chat_model)
# ─────────────────────────────────────────────────────────────
# Pick ANY provider. Leave everything unset to run with the built-in
# zero-config mock model.
#
# Examples:
#   OpenAI:     LLM_MODEL=gpt-4o-mini          + OPENAI_API_KEY
#   Anthropic:  LLM_MODEL=claude-sonnet-4-5    + ANTHROPIC_API_KEY  (LLM_PROVIDER=anthropic)
#   Google:     LLM_MODEL=gemini-2.0-flash     + GOOGLE_API_KEY     (LLM_PROVIDER=google_genai)
#   Ollama:     LLM_MODEL=llama3.1             + (LLM_PROVIDER=ollama)
#   IBM watsonx:LLM_MODEL=meta-llama/llama-3-3-70b-instruct + WATSONX_* (LLM_PROVIDER=ibm)

LLM_MODEL=gpt-4o-mini
# LLM_PROVIDER=openai
LLM_TEMPERATURE=0.7

# Provider API keys (set the one matching your model)
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=

# IBM watsonx (only if LLM_PROVIDER=ibm)
# WATSONX_URL=https://us-south.ml.cloud.ibm.com
# WATSONX_API_KEY=
# WATSONX_PROJECT_ID=

# Force the offline mock model regardless of the above
# USE_MOCK_LLM=true

# ─────────────────────────────────────────────────────────────
#  Tools (optional)
# ─────────────────────────────────────────────────────────────
# TAVILY_API_KEY=        # enables live web search in tools.py

# ─────────────────────────────────────────────────────────────
#  Persistence & server
# ─────────────────────────────────────────────────────────────
# Set a path to enable durable, resumable state across restarts.
# Leave unset for in-memory state.
# CHECKPOINT_DB=checkpoints.sqlite
PORT=8000
CORS_ORIGINS=*
LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────
#  Observability (optional) — LangSmith tracing
# ─────────────────────────────────────────────────────────────
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=langgraph-interrupt-template
